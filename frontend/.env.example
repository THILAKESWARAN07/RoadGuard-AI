# API Configuration
VITE_API_BASE_URL=http://localhost:8000

# Maps Configuration
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Application Configuration
VITE_APP_NAME=RoadGuard AI
VITE_ENVIRONMENT=development

# Feature Flags
VITE_ENABLE_WEBSOCKETS=false
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_PWA=false

# Map Configuration
VITE_DEFAULT_LATITUDE=28.6139
VITE_DEFAULT_LONGITUDE=77.2090
VITE_MAP_DEFAULT_ZOOM=14

# Refresh Configuration
VITE_DATA_REFRESH_INTERVAL_MS=20000

# Alert Configuration
VITE_ENABLE_AUDIO_ALERTS=true
VITE_ENABLE_SPEECH_ALERTS=true
